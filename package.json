  "scripts": {
    "start": "webpack-dev-server --host 127.0.0.1 --port 4000",
    "start-electron": "PLATFORM=electron webpack serve --host 127.0.0.1 --port 4000",
    "build": "NODE_ENV=production webpack",
    "build-web": "NODE_ENV=production PLATFORM=web webpack",
    "build-web-watch": "PLATFORM=web webpack --watch",
    "serve": "webpack serve --open",
    "build-electron": "PLATFORM=electron webpack",
    "build-android": "PLATFORM=android webpack",
    "add-android": "npx cap add android",
    "sync-android": "npx cap sync android",
    "open-android": "npx cap open android",
    "copy-android-assets": "npm run build-android && npx cap copy android",
    "open-studio": "npx cap open android --androidstudio",
    "build-apk": "npm run copy-android-assets && cd android && ./gradlew assembleDebug",
    "build-release-apk": "npm run copy-android-assets && cd android && ./gradlew assembleRelease"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jereidk/FunkyPacker.git"
  },
  "keywords": [
