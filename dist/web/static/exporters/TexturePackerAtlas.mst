{{config.imageFile}}
size: {{config.imageWidth}},{{config.imageHeight}}
format: {{config.format}}
filter: Linear,Linear
repeat: none
{{#rects}}
{{{name}}}
  rotate: {{#rotated}}true{{/rotated}}{{^rotated}}false{{/rotated}}
  xy: {{frame.x}}, {{frame.y}}
  size: {{frame.w}}, {{frame.h}}
  orig: {{sourceSize.w}}, {{sourceSize.h}}
  offset: {{spriteSourceSize.x}}, {{spriteSourceSize.y}}
  index: -1
{{/rects}}